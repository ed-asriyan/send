{
  "name": "SimpleX Send",
  "short_name": "SimpleX Send",
  "description": "Send files securely using SimpleX Network",
  "start_url": "./",
  "display": "standalone",
  "background_color": "#f0f4f8",
  "theme_color": "#ffffff",
  "icons": [
    {
      "src": "favicon.svg",
      "sizes": "any",
      "type": "image/svg+xml"
    },
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "*/*",
            "image/*",
            "video/*",
            "audio/*",
            "text/*",
            "application/*",
            ".pdf",
            ".doc",
            ".docx",
            ".zip",
            ".tar",
            ".gz",
            ".rar"
          ]
        }
      ]
    }
  }
}